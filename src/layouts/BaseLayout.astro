---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'me.',
	description = 'Diario pessoal e portfolio de textos autorais.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const faviconSvgHref = `${baseUrl}favicon.svg`;
const faviconIcoHref = `${baseUrl}favicon.ico`;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconSvgHref} />
		<link rel="icon" href={faviconIcoHref} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>